@inject NavigationManager Navigation

<nav class="flex flex-1 items-center space-x-4 lg:space-x-6">
    <a href="/" class="flex items-center space-x-2 mr-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 2a4 4 0 0 1 0 8 4 4 0 0 1 0 8"/>
            <path d="M2 12h20"/>
        </svg>
        <span class="font-bold text-lg">Lucazor</span>
    </a>
    <div class="flex items-center space-x-4 text-sm font-medium">
        <a href="/icons"
           class="transition-colors hover:text-foreground/80 @(IsActive("/icons") ? "text-foreground" : "text-foreground/60")">
            Icons
        </a>
        <a href="/docs/getting-started"
           class="transition-colors hover:text-foreground/80 @(IsActive("/docs") ? "text-foreground" : "text-foreground/60")">
            Docs
        </a>
        <a href="https://github.com/daeha76/Lucazor" target="_blank"
           class="transition-colors hover:text-foreground/80 text-foreground/60">
            GitHub
        </a>
        <a href="https://www.nuget.org/packages/Daeha.RnLucazor.Blazor" target="_blank"
           class="transition-colors hover:text-foreground/80 text-foreground/60">
            NuGet
        </a>
    </div>
    <div class="flex flex-1 items-center justify-end">
        <ThemeToggle />
    </div>
</nav>

@code {
    private bool IsActive(string prefix)
        => Navigation.Uri.Contains(prefix, StringComparison.OrdinalIgnoreCase);
}
