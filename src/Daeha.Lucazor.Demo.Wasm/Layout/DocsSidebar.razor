@inject NavigationManager Navigation
@implements IDisposable

<nav class="flex flex-col space-y-1">
    <div class="mb-4">
        <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2 px-2">
            Getting Started
        </p>
        <a href="/docs/getting-started"
           class="@NavItemClass("/docs/getting-started") flex items-center rounded-md px-2 py-1.5 text-sm font-medium transition-colors">
            Introduction
        </a>
        <a href="/docs/api"
           class="@NavItemClass("/docs/api") flex items-center rounded-md px-2 py-1.5 text-sm font-medium transition-colors">
            API Reference
        </a>
    </div>
    <div class="mb-4">
        <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2 px-2">
            Browse
        </p>
        <a href="/icons"
           class="@NavItemClass("/icons") flex items-center rounded-md px-2 py-1.5 text-sm font-medium transition-colors">
            Icon Gallery
        </a>
    </div>
    <div class="mb-4">
        <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2 px-2">
            Links
        </p>
        <a href="https://github.com/daeha76/Lucazor" target="_blank"
           class="flex items-center rounded-md px-2 py-1.5 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors">
            GitHub
        </a>
        <a href="https://www.nuget.org/packages/Daeha.RnLucazor.Blazor" target="_blank"
           class="flex items-center rounded-md px-2 py-1.5 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors">
            NuGet
        </a>
    </div>
</nav>

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private string NavItemClass(string href)
    {
        var isActive = Navigation.Uri.TrimEnd('/').EndsWith(href, StringComparison.OrdinalIgnoreCase);
        return isActive
            ? "bg-accent text-accent-foreground"
            : "text-muted-foreground hover:text-foreground hover:bg-accent/50";
    }
}
