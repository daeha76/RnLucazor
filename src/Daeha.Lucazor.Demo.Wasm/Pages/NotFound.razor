@page "/not-found"
@layout DocsLayout

<PageTitle>Page Not Found - Lucazor</PageTitle>

<div class="flex flex-col items-center justify-center min-h-[50vh] space-y-4 text-center">
    <div class="text-6xl font-bold text-muted-foreground">404</div>
    <h1 class="text-2xl font-semibold">Page Not Found</h1>
    <p class="text-muted-foreground max-w-sm">
        Sorry, the page you are looking for does not exist.
    </p>
    <a href="/"
       class="inline-flex items-center justify-center rounded-md bg-primary text-primary-foreground px-6 py-2.5 text-sm font-medium hover:opacity-90 transition-opacity mt-2">
        Go Home
    </a>
</div>
